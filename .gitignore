
# Dev/CI-only test tooling deps (testing/package.json) — the app itself needs no npm install.
testing/node_modules/

# Local Claude Code config (machine-specific — launch.json, settings*.json not shared)
# Agents and commands subdirs ARE tracked as shared project context.
.claude/*.json
.claude/.fpp-reminder-state

# Native Claude Code worktrees (created by /run-task via EnterWorktree) — local scratch, not shared.
.claude/worktrees/

# Python bytecode (testing/scripts/audit.py — stdlib health check, AUD-1)
__pycache__/
*.pyc
